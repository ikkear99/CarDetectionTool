# Example environment variables for vehicle counting tool
# Copy this file to .env and fill in your own values

VIDEO_DIR=video/（主）高崎渋川線（バイパス） ふれあい歩道橋/
REGION_PATH=output/region.txt
OUTPUT_EXCEL=output/results.xlsx
# API_KEY=your_api_key_here
# SECRET_KEY=your_secret_key_here
# DEBUG=False

# Microsoft Graph API credentials for OneDrive download
MS_CLIENT_ID=your_client_id_here
MS_TENANT_ID=your_tenant_id_here
MS_USERNAME=your_username_here
MS_PASSWORD=your_password_here
